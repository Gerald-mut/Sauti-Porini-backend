Invoke-WebRequest -Uri 'https://api.example.com/datasets' -Headers @{ "x-api-key" = "2fb4f1f7-bd93-4e9b-ae2a-1970ece8f893" } > datasets
Invoke-WebRequest -Uri 'https://data-api.globalforestwatch.org/datasets' -Headers @{ "x-api-key" = "2fb4f1f7-bd93-4e9b-ae2a-1970ece8f893" } > datasets
curl -X GET 'https://data-api.globalforestwatch.org/datasets' -H 'x-api-key: 2fb4f1f7-bd93-4e9b-ae2a-1970ece8f893' > datasets.json

$headers = @{
    "x-api-key" = "2fb4f1f7-bd93-4e9b-ae2a-1970ece8f893"
    "Content-Type" = "application/json"
}

Invoke-WebRequest -Uri 'https://data-api.globalforestwatch.org/datasets' -Headers $headers > datasets